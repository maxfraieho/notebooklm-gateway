modules = ["python-3.12", "web", "postgresql-16", "nodejs-22"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["alsa-lib", "at-spi2-core", "cairo", "chromium", "cups", "gitFull", "libxcrypt", "libxkbcommon", "mesa", "nspr", "nss", "pango", "playwright-driver", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXfixes", "xorg.libxcb"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "NotebookLM Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Memory Backend"

[[workflows.workflow]]
name = "NotebookLM Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m uvicorn app.main:app --host 0.0.0.0 --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Memory Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx src/server.ts"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "5000"]
build = ["bash", "-c", "pip install -r requirements.txt && playwright install chromium --with-deps || true"]

[userenv]

[userenv.shared]
MINIO_ENDPOINT = "https://apiminio.exodus.pp.ua"
MINIO_BUCKET = "mcpstorage"
MINIO_SECURE = "true"
GITHUB_REPO = "maxfraieho/garden-seedling"
GITHUB_BRANCH = "main"
